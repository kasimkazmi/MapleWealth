datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum AccountType {
  chequing
  savings
  tfsa
  fhsa
  rrsp
  non_registered
  credit_card
  loan
  cash
}

enum AccountPurpose {
  emergency
  vacation
  investment
  bills
  general
  home_down_payment
}

enum TransactionSource {
  manual
  csv
  api
}

enum AssetType {
  etf
  stock
  bond
  cash
  fund
}

enum GoalType {
  emergency_fund
  vacation
  net_worth
  home
  investment
  custom
}

enum RecurringRuleType {
  deposit
  investment_buy
  bill
  transfer
}

enum Frequency {
  weekly
  biweekly
  monthly
}

model User {
  id               String             @id @default(uuid()) @db.Uuid
  email            String             @unique
  name             String?
  emailVerified    Boolean            @default(false) @map("email_verified")
  image            String?
  country          String             @default("Canada")
  baseCurrency     String             @default("CAD")
  createdAt        DateTime           @default(now()) @db.Timestamptz
  updatedAt        DateTime           @updatedAt @db.Timestamptz
  financialProfile FinancialProfile?
  accounts         Account[]
  transactions     Transaction[]
  holdings         Holding[]
  contributions    Contribution[]
  dividends        Dividend[]
  goals            Goal[]
  recurringRules   RecurringRule[]
  auditLogs        AuditLog[]
  sessions         Session[]
  authAccounts     AuthAccount[]
  subscription     Subscription?
  approvedHoldings ApprovedHolding[]

  @@map("users")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @db.Timestamptz @map("created_at")
  updatedAt DateTime @updatedAt @db.Timestamptz @map("updated_at")

  @@map("sessions")
}

model AuthAccount {
  id                    String    @id @default(uuid()) @db.Uuid
  userId                String    @db.Uuid @map("user_id")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  password              String?
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  idToken               String?   @map("id_token")
  createdAt             DateTime  @default(now()) @db.Timestamptz @map("created_at")
  updatedAt             DateTime  @updatedAt @db.Timestamptz @map("updated_at")

  @@map("auth_accounts")
}

model Verification {
  id         String   @id @default(uuid()) @db.Uuid
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @db.Timestamptz @map("created_at")
  updatedAt  DateTime @updatedAt @db.Timestamptz @map("updated_at")

  @@map("verifications")
}

model Subscription {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @unique @db.Uuid @map("user_id")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status           String   // e.g. active, trialing, canceled, past_due
  planId           String   @map("plan_id") // e.g. free, premium, business
  currentPeriodEnd DateTime @map("current_period_end")
  createdAt        DateTime @default(now()) @db.Timestamptz @map("created_at")
  updatedAt        DateTime @updatedAt @db.Timestamptz @map("updated_at")

  @@map("subscriptions")
}

model FinancialProfile {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @db.Uuid @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  age             Int?
  annualSalary    Decimal  @db.Decimal(12, 2) @map("annual_salary")
  monthlyTakeHome Decimal  @db.Decimal(12, 2) @map("monthly_take_home")
  monthlyExpenses Decimal  @db.Decimal(12, 2) @map("monthly_expenses")
  savingsCapacity Decimal  @db.Decimal(12, 2) @map("savings_capacity")
  targetNetWorth  Decimal  @default(100000.00) @db.Decimal(12, 2) @map("target_net_worth")

  // Manually entered from the user's CRA My Account (CRA is the only authoritative source
  // for prior-year unused room; there is no public API to compute this automatically).
  // Represents unused room accumulated as of Jan 1 of the current calendar year.
  tfsaCarryForwardBase Decimal @default(0) @db.Decimal(12, 2) @map("tfsa_carry_forward_base")
  fhsaCarryForwardBase Decimal @default(0) @db.Decimal(12, 2) @map("fhsa_carry_forward_base")
  // RRSP deduction limit as shown on the user's latest CRA Notice of Assessment,
  // as of Jan 1 of the current calendar year (already includes all prior-year carry-forward).
  rrspKnownRoom        Decimal @default(0) @db.Decimal(12, 2) @map("rrsp_known_room")

  @@map("financial_profiles")
}

model Account {
  id             String         @id @default(uuid()) @db.Uuid
  userId         String         @db.Uuid @map("user_id")
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  institution    String
  name           String
  type           AccountType
  purpose        AccountPurpose
  currency       String         @default("CAD")
  currentBalance Decimal        @db.Decimal(14, 2) @map("current_balance")
  isActive       Boolean        @default(true) @map("is_active")
  transactions   Transaction[]
  holdings       Holding[]
  contributions  Contribution[]
  dividends      Dividend[]
  recurringRules RecurringRule[]

  @@index([userId])
  @@map("accounts")
}

model Transaction {
  id          String            @id @default(uuid()) @db.Uuid
  userId      String            @db.Uuid @map("user_id")
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId   String            @db.Uuid @map("account_id")
  account     Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  date        DateTime          @db.Date
  amount      Decimal           @db.Decimal(14, 2)
  currency    String
  category    String
  merchant    String?
  description String?
  source      TransactionSource @default(manual)

  @@index([userId])
  @@index([accountId])
  @@index([date])
  @@map("transactions")
}

model Holding {
  id           String     @id @default(uuid()) @db.Uuid
  userId       String     @db.Uuid @map("user_id")
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId    String     @db.Uuid @map("account_id")
  account      Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  symbol       String
  name         String
  assetType    AssetType  @map("asset_type")
  quantity     Decimal    @db.Decimal(20, 8)
  averageCost  Decimal    @db.Decimal(14, 4) @map("average_cost")
  currentPrice Decimal    @db.Decimal(14, 4) @map("current_price")
  dividends    Dividend[]

  @@index([userId])
  @@index([accountId])
  @@index([symbol])
  @@map("holdings")
}

model Contribution {
  id                    String      @id @default(uuid()) @db.Uuid
  userId                String      @db.Uuid @map("user_id")
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId             String      @db.Uuid @map("account_id")
  account               Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  registeredAccountType AccountType @map("registered_account_type")
  date                  DateTime    @db.Date
  amount                Decimal     @db.Decimal(14, 2)
  contributionYear      Int         @map("contribution_year")

  @@index([userId])
  @@index([accountId])
  @@map("contributions")
}

model Dividend {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId    String   @db.Uuid @map("account_id")
  account      Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  holdingId    String   @db.Uuid @map("holding_id")
  holding      Holding  @relation(fields: [holdingId], references: [id], onDelete: Cascade)
  payDate      DateTime @db.Date @map("pay_date")
  amount       Decimal  @db.Decimal(14, 2)
  reinvested   Boolean  @default(false)
  dripQuantity Decimal? @db.Decimal(20, 8) @map("drip_quantity")

  @@index([userId])
  @@index([accountId])
  @@index([holdingId])
  @@map("dividends")
}

model Goal {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @db.Uuid @map("user_id")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  type          GoalType
  targetAmount  Decimal   @db.Decimal(14, 2) @map("target_amount")
  currentAmount Decimal   @db.Decimal(14, 2) @map("current_amount")
  targetDate    DateTime? @db.Date @map("target_date")
  priority      Int       @default(1)

  @@index([userId])
  @@map("goals")
}

model ApprovedHolding {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol    String
  createdAt DateTime @default(now()) @db.Timestamptz @map("created_at")

  @@unique([userId, symbol])
  @@index([userId])
  @@map("approved_holdings")
}

model RecurringRule {
  id          String            @id @default(uuid()) @db.Uuid
  userId      String            @db.Uuid @map("user_id")
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId   String            @db.Uuid @map("account_id")
  account     Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  type        RecurringRuleType
  amount      Decimal           @db.Decimal(14, 2)
  frequency   Frequency
  nextRunDate DateTime          @db.Date @map("next_run_date")
  active      Boolean           @default(true)

  @@index([userId])
  @@index([accountId])
  @@map("recurring_rules")
}

model AuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  entityType    String   @map("entity_type")
  entityId      String   @db.Uuid @map("entity_id")
  action        String
  beforeJson    Json?    @map("before_json")
  afterJson     Json?    @map("after_json")
  correlationId String?  @map("correlation_id")
  createdAt     DateTime @default(now()) @db.Timestamptz @map("created_at")

  @@index([userId])
  @@index([correlationId])
  @@map("audit_logs")
}
